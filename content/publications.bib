  code = {https://github.com/Nanboy-Ronan/DUCK},
  abstract = {A fairness audit of medical AI agents that use tools for chest X-ray question answering. We propose a stage-wise fairness decomposition that breaks down end-to-end bias into three sources: tool exposure bias, tool transition bias, and model reasoning bias. Experiments reveal that demographic gaps persist in end-to-end performance, with equalized odds up to 20.79%.},
  keywords={Algorithm Fairness, Chest X-ray, Medical AI Agents, Fairness Decomposition}
}

